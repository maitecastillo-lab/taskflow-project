{
  "version": 2,
  "functions": {
    "server/index.js": {
      "runtime": "@vercel/node@3"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/server/index.js" },
    { "src": "/src/(.*)", "dest": "/src/$1" },
    { "src": "/(.*\\.(js|css|html|png|ico|svg))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}