{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/tasks/:path*",
      "destination": "/server/index.js"
    },
    {
      "source": "/api/v1/tasks",
      "destination": "/server/index.js"
    }
  ]
}

