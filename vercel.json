{
  "version": 2,
  "builds": [
    { "src": "server/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server/index.js" },
    { "src": "/src/api/(.*)", "dest": "/src/api/$1" },
    { "src": "/app.js", "dest": "/app.js" },
    { "src": "/index.html", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}